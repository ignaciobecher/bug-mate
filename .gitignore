report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json


#Claude
.claude

# Data — contains vectorized client knowledge (auto-generated)
/data/*
!/data/.gitkeep

# Client data — contains real client names, phones, companies
# Copy clients.example.json and fill with your own data
/config/clients.json

# Knowledge docs — may contain confidential client documentation
/config/knowledge-docs/*
!/config/knowledge-docs/.gitkeep
