# ─────────────────────────────────────────
# Ollama Configuration
# ─────────────────────────────────────────

# URL where Ollama is (or will be) running
OLLAMA_URL=http://localhost:11434

# Model to use for generation (must be pulled in Ollama first)
OLLAMA_MODEL=qwen3:8b

# Set to "true" to have the app spawn and manage the Ollama process automatically.
# Set to "false" if you prefer to run Ollama separately (e.g. already running, or via Docker).
OLLAMA_AUTO_START=true

# ─────────────────────────────────────────
# Bot Identity
# ─────────────────────────────────────────

# Name shown in escalation notifications
BOT_NAME=BugMate

# System prompt sent to the AI before every user message.
# Customize this to match your product and tone.
BOT_SYSTEM_PROMPT="Eres un asistente de soporte técnico para sistemas desarrollados por una software factory. Debes ayudar a los clientes respondiendo dudas comunes sobre el uso de los sistemas. Si el usuario necesita hablar con soporte humano, indícale que puede solicitarlo y será notificado el desarrollador. Responde de forma clara, breve y profesional."

# ─────────────────────────────────────────
# Developer Contact
# ─────────────────────────────────────────

# Name of the developer / support person to notify on escalation
DEVELOPER_NAME=Nacho

# WhatsApp phone number in international format — digits only, no + or spaces.
# Example: Argentina (+54) → 5491123456789
DEVELOPER_PHONE=5491123456789

# ─────────────────────────────────────────
# Escalation
# ─────────────────────────────────────────

# Comma-separated list of phrases that trigger escalation to the developer.
# The bot will notify the developer and reply to the client automatically.
ESCALATION_KEYWORDS=hablar con alguien,hablar con el desarrollador,soporte humano,quiero hablar con una persona,necesito ayuda humana,hablar con una persona real

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────

PORT=3000
